# ─── WhatsApp alerts (CallMeBot — free) ───────────────────────────────────────
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1) WhatsApp par +34 644 51 84 45 ko contact add karo (name: CallMeBot)
# 2) Us number ko message: I allow callmebot to send me messages
# 3) Jo API key reply aaye wo neeche daalo
# Phone: country code ke sath, + optional (e.g. +923001234567)
WHATSAPP_PHONE=
WHATSAPP_API_KEY=

# ─── Phone "app" alerts (NTFY — generic notification app) ───────────────────
# Play Store se "ntfy" install karo → Subscribe → topic naam neeche wala
# Notification title koi bhi rakho — random app jaisa dikhega
NTFY_TOPIC=mexc-watch-secret-change-me
NTFY_SERVER=https://ntfy.sh
NTFY_APP_TITLE=System Service

# Scanner
SCAN_INTERVAL_MS=120000
BREAKOUT_LOOKBACK=20
MIN_QUOTE_VOLUME_USDT=500000
MAX_SYMBOLS=0
ALERT_COOLDOWN_HOURS=8

# Web dashboard + browser alarm (http://localhost:3847)
WEB_PORT=3847
WEB_ENABLED=true
