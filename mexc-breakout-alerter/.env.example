# ─── Phone alarm app (recommended — random app jaisa, sirf alarm) ───────────
# 1) Play Store → "ntfy" install karo
# 2) App kholo → + → Subscribe to topic → neeche wala naam daalo
# 3) Phone settings → ntfy app → Notifications → sound ON, urgent/high
NTFY_TOPIC=device-care-x7k9m2
NTFY_SERVER=https://ntfy.sh
NTFY_APP_TITLE=Device Care

# Scanner
SCAN_INTERVAL_MS=120000
BREAKOUT_LOOKBACK=20
MIN_QUOTE_VOLUME_USDT=500000
MAX_SYMBOLS=0
ALERT_COOLDOWN_HOURS=8

# Web dashboard + browser alarm (http://localhost:3847)
WEB_PORT=3847
WEB_ENABLED=true

# WhatsApp (optional — default OFF)
# WHATSAPP_ENABLED=false
# WHATSAPP_PHONE=
# WHATSAPP_API_KEY=
